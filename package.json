{
  "name": "jagopakaiai-cli",
  "version": "1.0.1",
  "description": "JagoPakaiAI CLI utility for managing AI agent rule configurations",
  "main": "dist/index.js",
  "bin": {
    "jagopakaiai-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "mcp",
    "skills"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "test": "vitest run",
    "package": "npm run build && pkg . --out-path bin --no-bytecode"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "axios": "^1.6.8",
    "commander": "^12.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.1",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "pkg": {
    "assets": [
      "dist/index.js",
      "mcp/**/*",
      "skills/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-win-x64"
    ]
  }
}
